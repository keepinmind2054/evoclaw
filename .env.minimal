# EvoClaw minimal config — copy this file to .env and fill in your keys.
# Only the fields below are needed to get started.

# ── LLM (required — pick ONE) ───────────────────────────────────────────────
# Google Gemini — recommended for new users (free tier at aistudio.google.com)
GOOGLE_API_KEY=
# NVIDIA NIM — supports Qwen, Llama, Mistral, and many other models
# NIM_API_KEY=
# OpenAI — GPT-4 series
# OPENAI_API_KEY=
# Anthropic Claude — most reliable, but costs more
# CLAUDE_API_KEY=

# NOTE: There is no QWEN_API_KEY. To use Qwen models, set NIM_API_KEY (NVIDIA NIM)
# or set OPENAI_API_KEY + OPENAI_BASE_URL pointed at a Qwen-compatible endpoint.

# ── Chat channel (required — pick ONE) ──────────────────────────────────────
TELEGRAM_BOT_TOKEN=       # Obtain from @BotFather on Telegram
# DISCORD_BOT_TOKEN=      # From Discord Developer Portal
# SLACK_BOT_TOKEN=        # From Slack App configuration

# ── Assistant name (optional) ────────────────────────────────────────────────
ASSISTANT_NAME=EvoClaw

# ── Owner IDs (strongly recommended) ────────────────────────────────────────
# Comma-separated Telegram / Discord user IDs.
# These users are automatically granted admin rights on every startup.
# Without this, RBAC is in fail-open mode (all users are allowed).
#
# How to find your Telegram user ID: message @userinfobot on Telegram.
# How to find your Discord user ID: enable Developer Mode → right-click your avatar → Copy ID.
#
# Example: OWNER_IDS=123456789,987654321
OWNER_IDS=

# ── Security (recommended) ───────────────────────────────────────────────────
# Password for the web dashboard. Without this, the dashboard has NO authentication.
DASHBOARD_PASSWORD=
