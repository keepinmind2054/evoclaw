# EvoClaw minimal config — copy this file to .env and fill in your keys.
# Only the fields below are needed to get started.

# ── LLM (required — pick ONE) ───────────────────────────────────────────────
# Google Gemini — recommended for new users (free tier at aistudio.google.com)
GOOGLE_API_KEY=
# NVIDIA NIM — supports Qwen, Llama, Mistral, and many other models
# NIM_API_KEY=
# OpenAI — GPT-4 series
# OPENAI_API_KEY=
# Anthropic Claude — most reliable, but costs more
# CLAUDE_API_KEY=

# NOTE: There is no QWEN_API_KEY. To use Qwen models, set NIM_API_KEY (NVIDIA NIM)
# or set OPENAI_API_KEY + OPENAI_BASE_URL pointed at a Qwen-compatible endpoint.

# ── Chat channel (required — pick ONE) ──────────────────────────────────────
# Tell EvoClaw which channel(s) to activate (comma-separated).
# p12b: ENABLED_CHANNELS is required — without it the bot uses the default
# "telegram" but if TELEGRAM_BOT_TOKEN is not set it starts with NO channels.
ENABLED_CHANNELS=telegram
TELEGRAM_BOT_TOKEN=       # Obtain from @BotFather on Telegram
# DISCORD_BOT_TOKEN=      # From Discord Developer Portal — also set ENABLED_CHANNELS=discord
# SLACK_BOT_TOKEN=        # From Slack App configuration   — also set ENABLED_CHANNELS=slack

# ── Assistant name (optional) ────────────────────────────────────────────────
ASSISTANT_NAME=EvoClaw

# ── Owner IDs (strongly recommended) ────────────────────────────────────────
# Comma-separated Telegram / Discord user IDs.
# These users are automatically granted admin rights on every startup.
# Without this, RBAC is in fail-open mode (all users are allowed).
#
# How to find your Telegram user ID: message @userinfobot on Telegram.
# How to find your Discord user ID: enable Developer Mode → right-click your avatar → Copy ID.
#
# Example: OWNER_IDS=123456789,987654321
OWNER_IDS=

# ── Security (recommended) ───────────────────────────────────────────────────
# Password for the web dashboard. Without this, the dashboard has NO authentication.
DASHBOARD_PASSWORD=

# ── Optional: NIM model selection ────────────────────────────────────────────
# Only needed when NIM_API_KEY is set and you want a non-default model.
# NIM_MODEL=nvidia/llama-3.1-nemotron-ultra-253b-v1
# NIM_BASE_URL=https://integrate.api.nvidia.com/v1

# ── Optional: Gemini model selection ─────────────────────────────────────────
# GEMINI_MODEL=gemini-2.0-flash

# ── Optional: Anthropic model selection ──────────────────────────────────────
# CLAUDE_MODEL=claude-opus-4-6

# ── Optional: OpenAI model and endpoint ──────────────────────────────────────
# OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=https://api.openai.com/v1

# ── Optional: Monitor group for error alerts ─────────────────────────────────
# Telegram group JID — EvoClaw forwards container errors and heartbeat pings here.
# Easier: send /monitor from your Telegram group instead of editing this file.
# MONITOR_JID=tg:-1001234567890

# ── Optional: Container image ─────────────────────────────────────────────────
# The Docker image used for every agent run. Build with: make build
# Pin to a specific version tag in production to prevent silent regressions.
# CONTAINER_IMAGE=evoclaw-agent:latest

# ── Optional: Rate limiting ───────────────────────────────────────────────────
# Per-sender rate limit: max messages a single user may send per window.
# Users exceeding this receive "⚠️ 您傳送訊息的速度太快" and must wait.
# SENDER_RATE_LIMIT_MAX=5
# SENDER_RATE_LIMIT_WINDOW_SECS=60
#
# Per-group rate limit: max messages from an entire group per window.
# RATE_LIMIT_MAX_MSGS=20
# RATE_LIMIT_WINDOW_SECS=60

# ── Optional: Container resource limits ──────────────────────────────────────
# Memory per container (default 512m). Raise if you see "記憶體不足" errors.
# CONTAINER_MEMORY=512m
# CONTAINER_CPUS=1.0
# MAX_CONCURRENT_CONTAINERS=5
