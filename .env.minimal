# EvoClaw 最小設定（只填這些就能啟動）
# 複製此檔案為 .env 再填入你的 Key

# ── LLM（必填，選一個）──────────────────────────────────────
# 推薦：Qwen（便宜、中文最好）
QWEN_API_KEY=
# GOOGLE_API_KEY=         # Gemini 有免費 tier
# CLAUDE_API_KEY=         # 最穩定，但較貴
# OPENAI_API_KEY=         # GPT-4 系列

# ── 聊天頻道（必填，選一個）──────────────────────────────────
TELEGRAM_BOT_TOKEN=       # 從 @BotFather 取得
# DISCORD_BOT_TOKEN=      # 從 Discord Developer Portal 取得

# ── 助理名稱（選填）──────────────────────────────────────────
ASSISTANT_NAME=EvoClaw

# ── 擁有者 ID（強烈建議設定）────────────────────────────────
# Telegram 用 /userinfobot 取得你的 user ID
# Discord 開啟開發者模式 → 右鍵你的頭像 → 複製 ID
# 多個 ID 用逗號分隔，這些人自動獲得 admin 權限
OWNER_IDS=                # 例：123456789,987654321

# ── 安全設定（強烈建議）──────────────────────────────────────
DASHBOARD_PASSWORD=       # Web Dashboard 密碼，不填則無密碼保護
