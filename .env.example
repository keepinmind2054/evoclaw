# ── Evoclaw Configuration ────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Auto-detected: NIM_API_KEY present → NVIDIA NIM  |  GOOGLE_API_KEY → Gemini
# Force a specific provider (optional):
# LLM_PROVIDER=nim
# LLM_PROVIDER=gemini

# Google Gemini (default, free at https://aistudio.google.com/apikey)
# Supports comma-separated keys for automatic rotation on 429/quota errors (#6):
#   GOOGLE_API_KEY=key1,key2,key3
GOOGLE_API_KEY=your_google_api_key_here
# GEMINI_MODEL=gemini-2.0-flash

# NVIDIA NIM — OpenAI-compatible API (get key from https://build.nvidia.com)
# NIM_API_KEY=nvapi-your_nim_api_key_here
# NIM_BASE_URL=https://integrate.api.nvidia.com/v1
# NIM_MODEL=nvidia/llama-3.1-nemotron-ultra-253b-v1
# Other NIM model options:
#   meta/llama-3.3-70b-instruct
#   qwen/qwen3.5-397b-a17b
#   mistralai/mistral-large-2-instruct

# Assistant name (used as trigger: @AssistantName)
ASSISTANT_NAME=Eve

# ── Channels (enable at least one) ───────────────────────────────────────────
# Comma-separated list of enabled channels
ENABLED_CHANNELS=telegram

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# WhatsApp (Meta Cloud API)
# ENABLED_CHANNELS=telegram,whatsapp
WHATSAPP_TOKEN=your_whatsapp_api_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
WHATSAPP_VERIFY_TOKEN=your_webhook_verify_token_here
WHATSAPP_WEBHOOK_PORT=8080
# SECURITY: Set WHATSAPP_APP_SECRET to your Meta App Secret to enable HMAC-SHA256
# signature verification on incoming webhooks. Without this, the /webhook endpoint
# accepts payloads from ANY caller, not just Meta — a serious security gap.
# Find this in your Meta Developer Portal → App → Settings → Basic → App Secret.
# WHATSAPP_APP_SECRET=your_meta_app_secret_here

# Slack (Socket Mode — requires both tokens)
# ENABLED_CHANNELS=telegram,slack
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_APP_TOKEN=xapp-your-slack-app-token

# Discord
# ENABLED_CHANNELS=telegram,discord
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Gmail (OAuth2 — run setup to generate token)
# ENABLED_CHANNELS=telegram,gmail
GMAIL_CREDENTIALS_FILE=/home/user/.config/evoclaw/gmail_credentials.json
GMAIL_TOKEN_FILE=/home/user/.config/evoclaw/gmail_token.json
GMAIL_POLL_INTERVAL=30

# ── Optional ──────────────────────────────────────────────────────────────────

# Timezone
TZ=Asia/Taipei

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Log format: "text" (human-readable, default) or "json" (structured, for Loki/Datadog/CloudWatch)
# LOG_FORMAT=json

# Container settings
CONTAINER_IMAGE=evoclaw-agent:latest
CONTAINER_TIMEOUT=1800000
MAX_CONCURRENT_CONTAINERS=5
# Per-container resource limits — prevents runaway agents from OOM-killing the host (Issue #61).
# Set to empty string to disable: CONTAINER_MEMORY=  CONTAINER_CPUS=
CONTAINER_MEMORY=512m
CONTAINER_CPUS=1.0

# Polling intervals (milliseconds)
POLL_INTERVAL=2000
SCHEDULER_POLL_INTERVAL=60000
IPC_POLL_INTERVAL=1000

# Per-group message rate limiting (sliding window)
# A group sending more than RATE_LIMIT_MAX_MSGS within RATE_LIMIT_WINDOW_SECS has
# excess messages dropped to prevent one group from starving others.
# RATE_LIMIT_MAX_MSGS=20
# RATE_LIMIT_WINDOW_SECS=60

# Dashboard (web UI at http://DASHBOARD_HOST:DASHBOARD_PORT)
# DASHBOARD_HOST=127.0.0.1
# DASHBOARD_PORT=8765
# DASHBOARD_USER=admin
# DASHBOARD_PASSWORD=       # Set a non-empty password to enable HTTP Basic Auth

# Web Portal (browser chat UI at http://WEBPORTAL_HOST:WEBPORTAL_PORT)
# WEBPORTAL_ENABLED=false
# WEBPORTAL_HOST=127.0.0.1
# WEBPORTAL_PORT=8766

# Health check endpoint (used by load balancers / Docker HEALTHCHECK)
# HEALTH_PORT=8767
